{
  "rules": {
    ".read": false,
    ".write": false,
    "ageBands": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.admin === true)",
        ".write": "auth != null && auth.token.admin === true",
        ".validate": "newData.isString() && newData.val().matches(/^(U13|13-17|18[+])$/)"
      }
    },
    "friendAccess": {
      "$uid": {
        "$viewer": {
          ".read": "auth != null && (auth.uid === $uid || auth.uid === $viewer || auth.token.admin === true)",
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.isBoolean()"
        }
      }
    },
    "presence": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.admin === true || (data.child('visibility').val() === 'friends' && root.child('friendAccess').child($uid).child(auth.uid).val() === true) || (data.child('visibility').val() === 'everyone' && root.child('ageBands').child($uid).val() !== 'U13' && root.child('ageBands').child($uid).exists()))",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasOnly(['state','gameId','sessionId','joinable','visibility','joinPrivacy','lastChanged']) && newData.child('state').isString() && newData.child('state').val().matches(/^(online|playing|offline)$/) && newData.child('visibility').val().matches(/^(everyone|friends|nobody)$/) && newData.child('joinPrivacy').val().matches(/^(everyone|friends|nobody)$/) && (root.child('ageBands').child($uid).val() !== 'U13' || (newData.child('visibility').val() !== 'everyone' && newData.child('joinPrivacy').val() !== 'everyone'))"
      }
    },
    "sessions": {
      "$sessionId": {
        ".read": "auth != null && (data.child('hostId').val() === auth.uid || data.child('members').child(auth.uid).val() === true || root.child('friendAccess').child(data.child('hostId').val()).child(auth.uid).val() === true || auth.token.admin === true)",
        ".write": "auth != null && ((!data.exists() && newData.child('hostId').val() === auth.uid) || (data.exists() && data.child('hostId').val() === auth.uid && newData.child('hostId').val() === auth.uid))",
        ".validate": "newData.hasChildren(['hostId','gameId','maxPlayers']) && newData.child('maxPlayers').isNumber() && newData.child('maxPlayers').val() >= 1 && newData.child('maxPlayers').val() <= 8"
      }
    },
    "waitlists": {
      "$sessionId": {
        "$uid": {
          ".read": "auth != null && (auth.uid === $uid || root.child('sessions').child($sessionId).child('hostId').val() === auth.uid)",
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.hasOnly(['createdAt','notify']) && newData.child('notify').val() === true"
        }
      }
    }
  }
}
