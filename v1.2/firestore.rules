rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function owner(uid) { return signedIn() && request.auth.uid == uid; }
    function admin() { return signedIn() && request.auth.token.admin == true; }
    function ageBand(uid) { return get(/databases/$(database)/documents/ageBands/$(uid)).data.band; }
    function otherMember(data, uid) { return data.members[0] == uid ? data.members[1] : data.members[0]; }
    function parentApproved(uid, otherUid) { return ageBand(uid) in ['13-17', '18+'] || (ageBand(uid) == 'U13' && get(/databases/$(database)/documents/parentControls/$(uid)).data.approvedFriendIds.hasAny([otherUid])); }
    function chatAllowed(uid) { return ageBand(uid) in ['13-17', '18+'] || (ageBand(uid) == 'U13' && get(/databases/$(database)/documents/parentControls/$(uid)).data.chatEnabled == true); }
    function validGameStatus() { return request.resource.data.status in ['draft', 'submitted', 'requiredChanges', 'rejected', 'approved', 'published']; }
    function ownerGameCreate() {
      return signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.status in ['draft', 'submitted']
        && request.resource.data.visibility == 'visible'
        && request.resource.data.hasOnly(['title','url','ageRating','status','ownerId','notes','visibility']);
    }
    function ownerGameUpdate() {
      return signedIn()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId
        && validGameStatus()
        && (request.resource.data.status == resource.data.status || (resource.data.status in ['draft', 'requiredChanges', 'rejected'] && request.resource.data.status == 'submitted'))
        && (resource.data.status != 'published' || request.resource.data.url == resource.data.url)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title','url','pendingUrl','ageRating','notes','visibility','deleteAt','status']);
    }
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if owner(uid) && !('dob' in request.resource.data) && !('parentEmail' in request.resource.data);
      allow update: if owner(uid) && request.resource.data.username == resource.data.username && !('dob' in request.resource.data) && !('parentEmail' in request.resource.data);
      allow delete: if owner(uid) || admin();
      match /private/identity {
        allow read: if owner(uid) || admin();
        allow create, update, delete: if false;
      }
      match /preferences/{doc} { allow read, write: if owner(uid); }
      match /notifications/{id} { allow read, update, delete: if owner(uid); allow create: if (owner(uid) || admin()) && request.resource.data.recipientId == uid; }
    }
    match /games/{gameId} {
      // Published+visible games are public catalog entries even before SDK
      // integration passes — launch is gated server-side by sdkPassed.
      allow read: if (resource.data.status == 'published' && resource.data.visibility == 'visible') || admin() || (signedIn() && resource.data.ownerId == request.auth.uid);
      allow create: if ownerGameCreate();
      allow update: if (admin() && validGameStatus()) || ownerGameUpdate();
      allow delete: if admin();
    }
    match /friendships/{id} {
      allow read: if signedIn() && request.auth.uid in resource.data.members;
      allow create: if signedIn() && request.resource.data.members.size() == 2 && request.auth.uid in request.resource.data.members && request.resource.data.senderId == request.auth.uid && request.resource.data.status == 'pending' && parentApproved(request.auth.uid, otherMember(request.resource.data, request.auth.uid));
      allow update: if signedIn() && request.auth.uid in resource.data.members && request.auth.uid != resource.data.senderId && request.resource.data.members == resource.data.members && request.resource.data.senderId == resource.data.senderId && resource.data.status == 'pending' && request.resource.data.status in ['accepted', 'declined'] && (request.resource.data.status == 'declined' || parentApproved(request.auth.uid, resource.data.senderId));
      allow delete: if signedIn() && request.auth.uid in resource.data.members || admin();
    }
    match /threads/{id} {
      allow read: if signedIn() && request.auth.uid in resource.data.members;
      allow create, update, delete: if false;
    }
    match /threads/{id}/messages/{messageId} {
      function member() { return signedIn() && request.auth.uid in get(/databases/$(database)/documents/threads/$(id)).data.members; }
      allow read: if member();
      allow create, update, delete: if false;
    }
    match /reviews/{id} {
      function validReview() { return request.resource.data.stars >= 1 && request.resource.data.stars <= 5 && request.resource.data.text is string && request.resource.data.text.size() <= 500; }
      allow read: if true;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid && validReview();
      allow update: if signedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == resource.data.userId && request.resource.data.gameId == resource.data.gameId && validReview();
      allow delete: if signedIn() && resource.data.userId == request.auth.uid || admin();
    }
    match /reports/{id} { allow create, update, delete: if false; allow read: if admin(); }
    match /moderationTargets/{id} { allow read, write: if admin(); }
    match /parentConsents/{childUid} {
      allow read: if owner(childUid) || admin() || (signedIn() && request.auth.token.email_verified == true && request.auth.token.email == resource.data.parentEmail);
      allow create, update, delete: if false;
    }
    match /parentViews/{childUid} {
      allow write: if owner(childUid) && request.resource.data.hasOnly(['friends','pendingFriendIds','messageHistory','updatedAt']) && request.resource.data.friends is list && request.resource.data.friends.size() <= 50 && request.resource.data.pendingFriendIds is list && request.resource.data.pendingFriendIds.size() <= 50 && request.resource.data.messageHistory is list && request.resource.data.messageHistory.size() <= 500;
      allow read: if owner(childUid) || admin() || (signedIn() && request.auth.token.email_verified == true && request.auth.token.email == get(/databases/$(database)/documents/parentConsents/$(childUid)).data.parentEmail && get(/databases/$(database)/documents/parentConsents/$(childUid)).data.status == 'approved');
    }
    match /parentControls/{childUid} {
      function verifiedParent() { return signedIn() && request.auth.token.email_verified == true && request.auth.token.email == get(/databases/$(database)/documents/parentConsents/$(childUid)).data.parentEmail && get(/databases/$(database)/documents/parentConsents/$(childUid)).data.status == 'approved'; }
      allow read: if owner(childUid) || verifiedParent() || admin();
      allow create, update: if (verifiedParent() || admin()) && request.resource.data.hasOnly(['chatEnabled','approvedFriendIds']) && request.resource.data.chatEnabled is bool && request.resource.data.approvedFriendIds is list && request.resource.data.approvedFriendIds.size() <= 50;
      allow delete: if admin();
    }
    match /ageBands/{uid} {
      allow read: if owner(uid) || admin();
      allow create, update, delete: if false;
    }
    match /audit/{id} { allow read: if admin(); allow write: if false; }
    match /usernames/{username} { allow read: if true; allow create: if signedIn() && request.resource.data.uid == request.auth.uid; allow update, delete: if admin(); }
  }
}
